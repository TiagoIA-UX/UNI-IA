# ========================================================
# ZAIRYX IA / UNI IA - VARIÁVEIS DE AMBIENTE (EXEMPLO)
# ========================================================
# Copie este arquivo para .env.local na raiz do workspace
# e preencha com seus valores reais.
#
# ATENÇÃO: NUNCA comite o .env.local com valores reais.
# O .gitignore já protege este arquivo.

# === VERCEL DEPLOYMENT ===
VERCEL_TOKEN=vck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === SUPABASE (DATABASE & AUTH) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxx
# Alias aceito pelo env.ts (retrocompatibilidade)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxx

# === GROQ API (LLM) ===
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FORCE_JSON_MODE=true

# === TELEGRAM BOTS ===
# Token principal (fallback para bots individuais quando não definidos)
TELEGRAM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_FREE_CHANNEL=@your_free_channel
TELEGRAM_PREMIUM_CHANNEL=@your_premium_channel
TELEGRAM_FREE_BOT_USERNAME=your_free_bot
TELEGRAM_PREMIUM_BOT_USERNAME=your_premium_bot
TELEGRAM_FREE_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_PREMIUM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxx
# Controles de retry (opcionais - padrão: 10s timeout, 3 retries)
TELEGRAM_TIMEOUT_SECONDS=10
TELEGRAM_MAX_RETRIES=3

# === RESEND EMAILS ===
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === CRON JOB ===
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === UNI IA API (LOCAL SERVER / ai-sentinel) ===
UNI_IA_API_HOST=127.0.0.1
UNI_IA_API_PORT=8000
UNI_IA_MODEL_VERSION=v1

# === DESK (TRADING DESK - Mesa Privada) ===
# ATENÇÃO: DESK_MODE e DESK_REQUIRE_MANUAL_APPROVAL são os nomes lidos
# pelo desk.py. O alias UNI_IA_MODE e UNI_IA_REQUIRE_APPROVAL são
# mantidos aqui para documentação, mas NÃO são lidos pelo código atual.
DESK_MODE=paper
# paper = nunca envia ordem real | live = envia ordens reais via broker
DESK_REQUIRE_MANUAL_APPROVAL=true
DESK_ALLOWED_ASSETS=BTCUSDT,ETHUSDT,XRPUSDT
DESK_MIN_SCORE=75
DESK_STORE_TIMEOUT_SECONDS=10

# === BROKER INTEGRATION (Bybit V5) ===
BROKER_PROVIDER=bybit
BROKER_API_BASE_URL=https://api.bybit.com
BROKER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BROKER_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BROKER_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BROKER_TIMEOUT_SECONDS=10
BYBIT_RECV_WINDOW=5000
BYBIT_CATEGORY=linear
BYBIT_DEFAULT_QTY=0.001
BYBIT_SIGNAL_INTERVAL=15m

# === COPY TRADE ===
COPY_TRADE_ENABLED=false
COPY_TRADE_MIN_CONFIDENCE=75
COPY_TRADE_MAX_RISK_PERCENT=1.0

# === ATR STOP LOSS ===
ATR_SL_ENABLED=true
ATR_SL_MULTIPLIER=1.5
ATR_SL_PERIOD=14

# === BACKTEST & SIMULATION ===
BACKTEST_ASSET=BTCUSDT
BACKTEST_INITIAL_CAPITAL=10000
BACKTEST_FEE_RATE=0.0006
BACKTEST_SLIPPAGE_BPS=3
BACKTEST_SPREAD_BPS=1
BACKTEST_RISK_PER_TRADE_PCT=1.0
BACKTEST_MAX_DRAWDOWN_PCT_LIMIT=20
BACKTEST_FAST_SMA_PERIOD=5
BACKTEST_SLOW_SMA_PERIOD=20
BACKTEST_ATR_PERIOD=14
BACKTEST_ATR_MULTIPLIER=1.5
BACKTEST_MIN_SCORE=70
BACKTEST_MIN_ATR_PCT=0.002
BACKTEST_TAKE_PROFIT_RR=2.0

# === SIGNAL SCANNER ===
SIGNAL_SCANNER_ENABLED=false
SIGNAL_SCAN_ASSETS=BTCUSDT,ETHUSDT,XRPUSDT
SIGNAL_ALLOWED_CLASSIFICATIONS=OPORTUNIDADE
SIGNAL_MIN_SCORE=75
SIGNAL_SCAN_INTERVAL_SECONDS=60
SIGNAL_SCAN_STAGGER_SECONDS=2
SIGNAL_DEDUPE_TTL_SECONDS=300
SIGNAL_RECENT_LIMIT=20
SIGNAL_SESSION_FILTER_ENABLED=false
SIGNAL_DISPATCH_LOG_PATH=ai-sentinel/runtime_logs/signal_dispatch.jsonl

# === KILL SWITCH ===
KILL_SWITCH_ENABLED=true
KILL_SWITCH_MAX_DAILY_LOSS_PCT=3.0
KILL_SWITCH_MAX_DRAWDOWN_PCT=10.0
KILL_SWITCH_WINDOW_DAYS=1
KILL_SWITCH_SAMPLE_LIMIT=5000
KILL_SWITCH_LOG_PATH=ai-sentinel/runtime_logs/risk_events.jsonl

# === AUDIT & LOGGING ===
AUDIT_TABLE_NAME=uni_ia_operational_audit
AUDIT_TIMEOUT_SECONDS=10
AUDIT_EVENT_VARIANT=A
AUDIT_EVENT_PAGE=ai-sentinel-operational
AUDIT_EVENT_LOCALE=pt-BR
FEATURE_STORE_LOG_PATH=ai-sentinel/runtime_logs/feature_store.jsonl
FEEDBACK_LOG_PATH=ai-sentinel/runtime_logs/feedback.jsonl
FEEDBACK_STORE_TIMEOUT_SECONDS=10
OUTCOME_LOG_PATH=ai-sentinel/runtime_logs/outcomes.jsonl
OUTCOME_TRACKER_TIMEOUT_SECONDS=10

# === STRATEGY & AGENTS ===
STRATEGY_DEFAULT_MODE=swing
AEGIS_ENABLE_DYNAMIC_RECALIBRATION=false
AEGIS_RECALIBRATION_WINDOW_DAYS=90
AEGIS_RECALIBRATION_MIN_SAMPLES=5

# === CORS (ai-sentinel FastAPI) ===
# Origens permitidas separadas por vírgula. Deixe em branco só em desenvolvimento local.
ALLOWED_ORIGINS=https://zairyx.ai,https://www.zairyx.ai

# === DESK (nomes lidos pelo desk.py — não alterar) ===
# DESK_MODE=paper        # paper | live
# DESK_REQUIRE_MANUAL_APPROVAL=true

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID=cole_aqui_o_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=cole_aqui_a_chave_secreta