# ========================================================
# UNI IA - VARIÁVEIS DE AMBIENTE (EXEMPLO)
# ========================================================
# Copie este arquivo para .env.local na raiz do workspace
# e preencha com seus valores reais.
#
# ATENÇÃO: NUNCA comite o .env.local com valores reais.
# O .gitignore já protege este arquivo.

# === VERCEL DEPLOYMENT ===
VERCEL_TOKEN=your_vercel_token_here

# === SUPABASE (DATABASE & AUTH) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Alias aceito pelo env.ts (retrocompatibilidade)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# URL base da API ai-sentinel (plataforma / Next.js)
NEXT_PUBLIC_AI_API_URL=http://127.0.0.1:8000
#
# --- Segurança / monorepo (sem expor credenciais no Next) ---
# O ficheiro zairyx-frontend/next.config.ts só repete para o processo Node do
# Next as chaves em PARENT_ENV_ALLOWLIST. Tokens só de backend (Groq, Telegram,
# etc.) no .env.local da raiz NÃO são lidos pelo Next — o ai-sentinel Python
# continua a ler o .env.local completo por conta própria.
# Para mudar só a URL da API da plataforma, pode criar zairyx-frontend/.env.local
# com uma linha: NEXT_PUBLIC_AI_API_URL=http://127.0.0.1:8000
# (gitignore cobre *.local; não commite valores reais.)

# === GROQ API (LLM) ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FORCE_JSON_MODE=true

# === LLM FAILURE ALERT ===
# Quando o Groq retornar erro (429, 5xx ou timeout), o sistema interrompe
# o ciclo e dispara alerta via Telegram ao canal administrativo.
# Nenhum sinal é gerado com payload inválido (Mandato Zero Bug).
LLM_FAILURE_ALERT_ENABLED=true

# === TELEGRAM BOTS ===
# Token principal (fallback para bots individuais quando não definidos)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_FREE_CHANNEL=@your_free_channel
TELEGRAM_PREMIUM_CHANNEL=@your_premium_channel
TELEGRAM_FREE_BOT_USERNAME=your_free_bot_username
TELEGRAM_PREMIUM_BOT_USERNAME=your_premium_bot_username
TELEGRAM_FREE_BOT_TOKEN=your_free_bot_token
TELEGRAM_PREMIUM_BOT_TOKEN=your_premium_bot_token
# Controles de retry (opcionais - padrão: 10s timeout, 3 retries)
TELEGRAM_TIMEOUT_SECONDS=10
TELEGRAM_MAX_RETRIES=3

# === TELEGRAM ADMIN (necessário para alertas operacionais) ===
# Para descobrir seu chat_id: envie uma mensagem ao seu bot
# e consulte /api/telegram/status → campo last_seen_chat_id
TELEGRAM_ADMIN_CHAT_IDS=your_admin_chat_id
TELEGRAM_ADMIN_USER_IDS=your_admin_user_id
TELEGRAM_CONTROL_ENABLED=false

# === RESEND EMAILS ===
RESEND_API_KEY=your_resend_api_key

# === CRON JOB ===
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_generated_cron_secret

# === UNI IA API (LOCAL SERVER / ai-sentinel) ===
UNI_IA_API_HOST=127.0.0.1
UNI_IA_API_PORT=8000
UNI_IA_MODEL_VERSION=v1
# Obrigatório em produção; usado no header X-UNI-IA-ADMIN-TOKEN nas rotas /api/admin/*
UNI_IA_ADMIN_TOKEN=gerar_token_forte_hex_ou_uuid

# === UNI IA — MESA E EXECUÇÃO (ai-sentinel) ===
# Modo da mesa: paper | approval | live (lido por api/desk.py como UNI_IA_MODE)
UNI_IA_MODE=paper
# Em live com true, sinais IA ficam pendentes até POST /api/desk/approve/{id}
UNI_IA_REQUIRE_APPROVAL=true
# Whitelist: use o mesmo formato que o broker (ex. BTCBRL, ETHBRL ou BTCUSDT)
DESK_ALLOWED_ASSETS=BTCBRL,ETHBRL
DESK_MIN_SCORE=75
DESK_STORE_TIMEOUT_SECONDS=10

# Execução automática a partir de sinais (scanner → mesa → copy trade)
COPY_TRADE_ENABLED=false
COPY_TRADE_MIN_CONFIDENCE=75
COPY_TRADE_MAX_RISK_PERCENT=1.0

# Broker: mercadobitcoin (padrão TAPI v3 MB) | bybit | generic
BROKER_PROVIDER=mercadobitcoin
BROKER_API_KEY=your_mb_tapi_id
BROKER_API_SECRET=your_mb_tapi_secret
BROKER_API_BASE_URL=https://www.mercadobitcoin.com.br
MB_DEFAULT_QTY=0.0001
MB_TRADE_START_HOUR=9
MB_TRADE_END_HOUR=22
MB_ORDER_TIMEOUT_HOURS=4
BROKER_TIMEOUT_SECONDS=10

# === DESK (aliases legados — preferir UNI_IA_MODE acima) ===
DESK_MODE=paper
DESK_REQUIRE_MANUAL_APPROVAL=true

# === BROKER BYBIT (opcional — BROKER_PROVIDER=bybit) ===
BYBIT_API_BASE_URL=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_RECV_WINDOW=5000
BYBIT_CATEGORY=linear
BYBIT_DEFAULT_QTY=0.001
BYBIT_SIGNAL_ASSETS=BTCUSDT,ETHUSDT,SOLUSDT
BYBIT_SIGNAL_INTERVAL=15m

# === ATR STOP LOSS ===
ATR_SL_ENABLED=true
ATR_SL_MULTIPLIER=1.5
ATR_SL_PERIOD=14

# === BACKTEST & SIMULATION ===
BACKTEST_ASSET=BTCUSDT
BACKTEST_INITIAL_CAPITAL=10000
BACKTEST_FEE_RATE=0.0006
BACKTEST_SLIPPAGE_BPS=3
BACKTEST_SPREAD_BPS=1
BACKTEST_RISK_PER_TRADE_PCT=1.0
BACKTEST_MAX_DRAWDOWN_PCT_LIMIT=20
BACKTEST_FAST_SMA_PERIOD=5
BACKTEST_SLOW_SMA_PERIOD=20
BACKTEST_ATR_PERIOD=14
BACKTEST_ATR_MULTIPLIER=1.5
BACKTEST_MIN_SCORE=70
BACKTEST_MIN_ATR_PCT=0.002
BACKTEST_TAKE_PROFIT_RR=2.0

# === SIGNAL SCANNER ===
SIGNAL_SCANNER_ENABLED=false
SIGNAL_SCAN_ASSETS=BTCUSDT,ETHUSDT,XRPUSDT
SIGNAL_ALLOWED_CLASSIFICATIONS=OPORTUNIDADE
SIGNAL_MIN_SCORE=75
SIGNAL_SCAN_INTERVAL_SECONDS=60
SIGNAL_SCAN_STAGGER_SECONDS=2
SIGNAL_DEDUPE_TTL_SECONDS=300
SIGNAL_RECENT_LIMIT=20
SIGNAL_SESSION_FILTER_ENABLED=false
SIGNAL_DISPATCH_LOG_PATH=ai-sentinel/runtime_logs/signal_dispatch.jsonl

# === KILL SWITCH ===
KILL_SWITCH_ENABLED=true
KILL_SWITCH_MAX_DAILY_LOSS_PCT=3.0
KILL_SWITCH_MAX_DRAWDOWN_PCT=10.0
KILL_SWITCH_WINDOW_DAYS=1
KILL_SWITCH_SAMPLE_LIMIT=5000
KILL_SWITCH_LOG_PATH=ai-sentinel/runtime_logs/risk_events.jsonl

# === AUDIT & LOGGING ===
AUDIT_TABLE_NAME=uni_ia_operational_audit
AUDIT_TIMEOUT_SECONDS=10
AUDIT_EVENT_VARIANT=A
AUDIT_EVENT_PAGE=ai-sentinel-operational
AUDIT_EVENT_LOCALE=pt-BR
FEATURE_STORE_LOG_PATH=ai-sentinel/runtime_logs/feature_store.jsonl
FEEDBACK_LOG_PATH=ai-sentinel/runtime_logs/feedback.jsonl
FEEDBACK_STORE_TIMEOUT_SECONDS=10
OUTCOME_LOG_PATH=ai-sentinel/runtime_logs/outcomes.jsonl
OUTCOME_TRACKER_TIMEOUT_SECONDS=10

# ARGUS: regista posicao em paper (sem broker) para ranking/outcomes — default false
ARGUS_REGISTER_PAPER_OPPORTUNITY=false

# === STRATEGY & AGENTS ===
STRATEGY_DEFAULT_MODE=swing
AEGIS_ENABLE_DYNAMIC_RECALIBRATION=false
AEGIS_RECALIBRATION_WINDOW_DAYS=90
AEGIS_RECALIBRATION_MIN_SAMPLES=5

# === CORS (ai-sentinel FastAPI) ===
# Origens permitidas separadas por vírgula. Deixe em branco só em desenvolvimento local.
ALLOWED_ORIGINS=https://zairyx.ai,https://www.zairyx.ai

# === DESK (duplicado removido — ver bloco UNI IA acima) ===

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
